<Window x:Class="WordCloud.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:local="clr-namespace:WordCloud"
        mc:Ignorable="d"
        FontSize="{StaticResource NormalFontSize}"
        Title="Word Cloud Generator" Height="720" Width="1280" Loaded="Window_Loaded">
    <Grid Margin="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="256"/>
            <ColumnDefinition Width="0.618*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto" MaxHeight="72"/>
        </Grid.RowDefinitions>
        <TextBox Grid.Column="0" Grid.Row="0" Name="WordsTextBox" TextWrapping="Wrap" AcceptsReturn="True" 
                 Margin="4" MaxWidth="400"
                 FontFamily="{StaticResource MonoSpaceFamily}" FontSize="{StaticResource MonoSpaceFontSize}"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" 
                 VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
        <Border Grid.Column="1" Grid.Row="0" Margin="4" BorderBrush="DarkGray" BorderThickness="1">
            <Border.Background>
                <ImageBrush ImageSource="pack://application:,,,/WordCloud;component/Resources/checkerboard.png" TileMode="Tile" Opacity="0.20" ViewportUnits="Absolute" Viewport="0,0,32,32"/>
            </Border.Background>
            <Image Margin="4" Name="WordCloudImage" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" StretchDirection="DownOnly" />
        </Border>
        <xctk:BusyIndicator Grid.Column="1" Grid.Row="0" x:Name="CloudBuildingIndicator" x:Uid="CloudBuildingIndicator" MinWidth="128" MinHeight="96" Margin="4" 
            VerticalAlignment="Center" HorizontalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
            BusyContent="Building ..." Background="Transparent" IsBusy="False" ForceCursor="True" IsManipulationEnabled="True" />
        <WrapPanel Grid.Column="0" Grid.Row="1" Margin="4" VerticalAlignment="Center" HorizontalAlignment="Center" >
            <Button Name="SaveWordsCloud" x:Uid="SaveWordsCloud" Content="Save" VerticalAlignment="Center" HorizontalAlignment="Left" Height="32" MinWidth="64" Margin="8" Padding="4" Click="SaveWordsCloud_Click" />
            <Button Name="BuildWordsCloud" x:Uid="BuildWordsCloud" Content="Build" VerticalAlignment="Center" HorizontalAlignment="Left" Height="32" MinWidth="64" Margin="8" Padding="4" Click="BuildWordsCloud_Click" />
        </WrapPanel>
        <Grid Grid.Column="1" Grid.Row="1" Margin="4" VerticalAlignment="Center"  HorizontalAlignment="Center" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" x:Name="CloudWidthLabel" x:Uid="CloudWidthLabel" Text="W:" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="4" MinWidth="24" />
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="CloudWidthValue" x:Uid="CloudWidthValue" Text="" VerticalAlignment="Center" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="4" Width="64" FontFamily="{StaticResource MonoSpaceFamily}" TextChanged="CloudWidthValue_TextChanged" />
            <TextBlock Grid.Row="1" Grid.Column="0" x:Name="CloudHeightLabel" x:Uid="CloudHeightLabel" Text="H:" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="4" MinWidth="24" />
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="CloudHeightValue" x:Uid="CloudHeightValue" Text="" VerticalAlignment="Center" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="4" Width="64" FontFamily="{StaticResource MonoSpaceFamily}" TextChanged="CloudHeightValue_TextChanged" />
            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="CloudFontLabel" x:Uid="CloudFontLabel" Text="Font:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4" MinWidth="32" />
            <ComboBox Grid.Row="0" Grid.Column="3" x:Name="CloudFontValue" x:Uid="CloudFontValue" Text="" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="4" Padding="4" MinWidth="128" MaxWidth="384" IsReadOnly="True" AlternationCount="2" IsManipulationEnabled="True" SelectionChanged="CloudFontValue_SelectionChanged"/>
            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="CloudOrientationLabel" x:Uid="CloudOrientationLabel" Text="Orientation:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4" MinWidth="32" />
            <ComboBox Grid.Row="1" Grid.Column="3" x:Name="CloudOrientationValue" x:Uid="CloudOrientationValue" Text="" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="4" Padding="4" MinWidth="128" MaxWidth="384" IsReadOnly="True" AlternationCount="2" IsManipulationEnabled="True" SelectionChanged="CloudOrientationValue_SelectionChanged"/>
            <TextBlock Grid.Row="0" Grid.Column="4" x:Name="CloudBackgroundLabel" x:Uid="CloudBackgroundLabel" Text="Background:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4" MinWidth="32" />
            <ComboBox Grid.Row="0" Grid.Column="5" x:Name="CloudBackgroundValue" x:Uid="CloudBackgroundValue" Text="" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="4" Padding="4" MinWidth="128" MaxWidth="384" IsReadOnly="True" AlternationCount="2" IsManipulationEnabled="True" SelectionChanged="CloudBackgroundValue_SelectionChanged"/>
            <TextBlock Grid.Row="1" Grid.Column="4" x:Name="CloudMaskImageLabel" x:Uid="CloudMaskImageLabel" Text="Mask Image:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4" MinWidth="32" />
            <ComboBox Grid.Row="1" Grid.Column="5" x:Name="CloudMaskImageValue" x:Uid="CloudMaskImageValue" Text="" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="4" Padding="4" MinWidth="128" MaxWidth="384" IsReadOnly="True" AlternationCount="2" IsManipulationEnabled="True" SelectionChanged="CloudMaskImageValue_SelectionChanged"/>
            <Button Grid.Row="0" Grid.Column="6"  x:Name="CloudBackImagePick" x:Uid="CloudBackImagePick" Content="&#xE197;" FontFamily="{StaticResource ExtraIconFamily}" ToolTip="Pick Back Image" VerticalAlignment="Center" HorizontalAlignment="Left" Height="26" Width="26" Margin="4" Padding="4" Click="CloudBackImagePick_Click" />
            <xctk:ColorPicker Grid.Row="0" Grid.Column="7" x:Name="CloudBackColorPick" x:Uid="CloudBackColorPick" Height="24" Width="24" Margin="2 0" SelectedColor="Transparent" 
                ToolTip="Background Color Picker" FontFamily="{DynamicResource MonoSpaceFamily}" 
                ShowDropDownButton="False" ShowAvailableColors="True" ShowRecentColors="True" DisplayColorAndName="False" DisplayColorTooltip="True"
                SelectedColorChanged="CloudBackColorPick_SelectedColorChanged">
            </xctk:ColorPicker>
            <Button Grid.Row="1" Grid.Column="6"  x:Name="CloudMaskImagePick" x:Uid="CloudMaskImagePick" Content="&#xE197;" FontFamily="{StaticResource ExtraIconFamily}" ToolTip="Pick Mask Image" VerticalAlignment="Center" HorizontalAlignment="Left" Height="26" Width="26" Margin="4" Padding="4" Click="CloudMaskImagePick_Click" />
            <TextBlock Grid.Row="1" Grid.Column="8" x:Name="CloudMarginLabel" x:Uid="CloudMarginLabel" Text="Margin:" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="4" MinWidth="24" />
            <TextBox Grid.Row="1" Grid.Column="9" x:Name="CloudMarginValue" x:Uid="CloudMarginValue" Text="" VerticalAlignment="Center" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="4" Width="64" FontFamily="{StaticResource MonoSpaceFamily}" TextChanged="CloudMarginValue_TextChanged" />
        </Grid>
    </Grid>
</Window>
