<Window x:Class="WordCloud.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WordCloud"
        mc:Ignorable="d"
        Title="Word Cloud Generator" Height="720" Width="1280" Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.5*"/>
            <ColumnDefinition Width="0.5*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="96"/>
        </Grid.RowDefinitions>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/WordCloud;component/Resources/checkerboard.png" TileMode="Tile" Opacity="0.10" ViewportUnits="Absolute" Viewport="0,0,32,32"/>
        </Grid.Background>
        <TextBox Grid.Column="0" Grid.Row="0" Margin="4" Name="WordsTextBox" TextWrapping="Wrap" AcceptsReturn="True" 
                 FontFamily="{StaticResource MonoSpaceFamily}"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" 
                 VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
        <Image Grid.Column="1" Grid.Row="0" Margin="4" Name="WordCloudImage" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" StretchDirection="DownOnly" />
        <WrapPanel Grid.Column="0" Grid.Row="1" Margin="4" VerticalAlignment="Center"  HorizontalAlignment="Left">
            <Button Margin="4" Name="SaveWordsCloud" Content="Save" VerticalAlignment="Center" HorizontalAlignment="Left" Click="SaveWordsCloud_Click" />
            <Button Margin="4" Name="BuildWordsCloud" Content="Build" VerticalAlignment="Center" HorizontalAlignment="Left" Click="BuildWordsCloud_Click" />
        </WrapPanel>
        <WrapPanel Grid.Column="1" Grid.Row="1" Margin="4" VerticalAlignment="Center"  HorizontalAlignment="Left">
            
        </WrapPanel>
    </Grid>
</Window>
